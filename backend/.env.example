# Server
HOST=0.0.0.0
PORT=8000

# Environment: development | production
ENV=development

# CORS (comma-separated origins in production)
CORS_ORIGINS=http://localhost:5173

# Chat gateway (v1): Bearer token for clients
CHAT_API_KEY=dev-key

# Internal LLM (OpenAI-compatible); gateway proxies to this
INTERNAL_LLM_BASE_URL=http://127.0.0.1:8001
# Optional: if set, gateway sends Authorization: Bearer <key> to internal LLM
INTERNAL_LLM_API_KEY=
