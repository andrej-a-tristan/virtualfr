# Server
HOST=0.0.0.0
PORT=8000

# Environment: development | production
ENV=development

# CORS (comma-separated origins in production)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Supabase (required for DB; get from project Settings > API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# API key for external services (e.g. OpenAI); optional
API_KEY=

# Chat gateway (v1): Bearer token for clients
CHAT_API_KEY=dev-key

# Internal LLM (OpenAI-compatible); gateway proxies to this
INTERNAL_LLM_BASE_URL=http://127.0.0.1:8001
# Optional: if set, gateway sends Authorization: Bearer <key> to internal LLM
INTERNAL_LLM_API_KEY=

# Stripe (for billing + gifting)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_FREE=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PREMIUM=
STRIPE_SUCCESS_URL=http://localhost:5173/app/chat?gift_success=1
STRIPE_CANCEL_URL=http://localhost:5173/app/chat?gift_cancel=1
